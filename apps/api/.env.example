PORT=8787
DATABASE_PATH=./data/trexx.db
CORS_ORIGINS=http://localhost:5173
# With ngrok on Vite (single tunnel): add the tunnel HTTPS origin, e.g.:
# CORS_ORIGINS=http://localhost:5173,https://xxxx.ngrok-free.app

# Soroban / identity
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
ESCROW_CONTRACT_ID=
USDC_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
TOKEN_DECIMALS=7
PLATFORM_PUBLIC_KEY=
OPERATOR_SECRET=

# x402 — POST /api/clips
# X402_PAY_TO is usually the same address that receives off-chain fees (platform wallet G…).
X402_PAY_TO=
X402_CLIP_PRICE=0.01
# Public HTTPS URL for POST /api/clips (required for cloud facilitator).
#
# Note: free ngrok-free.* domains may cause facilitator verify to fail (fetch failed),
# because the facilitator server does not send ngrok-skip-browser-warning. Host the API publicly or use a paid tunnel.
# Option A — one tunnel (recommended): ngrok → Vite :5173; /api proxies to this API.
#   X402_RESOURCE_URL=https://YOUR_TUNNEL.ngrok-free.app/api/clips
#   Web: leave VITE_API_URL unset (/api on the same tunnel host).
#   TRUST_PROXY=1 so Express sees https (X-Forwarded-Proto from proxy).
#
# Option B — two tunnels: one for API :8787 and one for Vite :5173.
#   X402_RESOURCE_URL=https://TUNNEL-API.ngrok-free.app/api/clips
#   Web: VITE_API_URL=https://TUNNEL-API.ngrok-free.app (CORS: include TUNNEL-WEB origin).
X402_RESOURCE_URL=
# Behind proxy/ngrok (option A)
# TRUST_PROXY=1
# X402_DISABLED=true

# @x402/core default is https://x402.org/facilitator; POST gets 308 → www and Node fetch breaks.
# This API forces https://www.x402.org/facilitator. Override only if you know why:
# X402_FACILITATOR_URL=https://www.x402.org/facilitator
